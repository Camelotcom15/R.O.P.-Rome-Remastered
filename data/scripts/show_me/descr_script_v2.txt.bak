script

;console_command toggle_perfect_spy

;suspend_unscripted_advice true

;---------------------------------
;-------Government Triggers-------
;---------------------------------

;ROP has three governments: Monarchy(one), Oligarchy(few) and Democracy(many)
;Monarchy and Oligarchy are widespread in the beginning of the campaign, but Democracy spawns from Athens

monitor_event CharacterTurnEndInSettlement AgentType = family
and SettlementName Abydos
and Trait Oligarchy > 0
and not FactionType slave
and SettlementBuildingExists >= governors_house
and not SettlementBuildingExists >= preq_gov_oligarchy
and RemainingMPPercentage = 100

	console_command create_building Abydos "preq_gov_oligarchy"
	
end_monitor

monitor_event CharacterTurnEndInSettlement AgentType = family
and SettlementName Abydos
and Trait Monarchy > 0
and not FactionType slave
and SettlementBuildingExists >= governors_house
and not SettlementBuildingExists >= preq_gov_monarchy
and RemainingMPPercentage = 100

	console_command create_building Abydos "preq_gov_monarchy"
	
end_monitor

monitor_event CharacterTurnEndInSettlement AgentType = family
and SettlementName Abydos
and Trait Democracy > 0
and not FactionType slave
and SettlementBuildingExists >= governors_house
and not SettlementBuildingExists >= preq_gov_democracy
and RemainingMPPercentage = 100

	console_command create_building Abydos "preq_gov_democracy"
	
end_monitor

